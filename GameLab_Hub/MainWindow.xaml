<Window x:Class="GameLab_Hub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:GameLab_Hub"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <TabControl TabStripPlacement = "Top" Name="tabCTRL">

        <TabItem x:Name="tblmSearchSoftware" Loaded="tblmSearchSoftware_Loaded">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Computer"
                                             Width="25"
                                             Height="25"
                                             VerticalAlignment="Center"
                                             Margin ="0,0,10,0"
                                             Foreground="#4B0082"/>
                    <TextBlock Text="Search Software"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="#8A2BE2"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>

                <ListBox x:Name="lbxListOfComputer" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,38,521,10" SelectionChanged="lbxListOfComputer_SelectionChanged"/>
                <Label x:Name="lblComputerlab" Content="Search:" HorizontalAlignment="Left" Margin="268,14,0,0" VerticalAlignment="Top" FontWeight="Bold" Foreground="DarkSlateGray"/>
                <TextBox x:Name="tbxSearch" HorizontalAlignment="Left" Margin="319,14,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" KeyUp="tbxSearch_KeyUp"/>
                <Button x:Name="btnTimetable" Content="Timetable" HorizontalAlignment="Left" Margin="652,303,0,0" VerticalAlignment="Top" Background="Cyan" BorderBrush="Cyan" Foreground="DarkSlateGray" FontWeight="Bold" Click="btnTimetable_Click"/>
                <Button x:Name="btnExamLabs" Content="Exam Labs" HorizontalAlignment="Left" Margin="457,303,0,0" VerticalAlignment="Top" FontWeight="Bold" Background="DeepPink" Foreground="DarkSlateGray" BorderBrush="DeepPink" Click="btnExamLabs_Click"/>
                <TextBlock x:Name="tblRoominfo" HorizontalAlignment="Left" Margin="483,46,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="220" Width="278" Text="RoomInfo"/>

            </Grid>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Timetable"
                                       Width="25"
                                       Height="25"
                                       VerticalAlignment="Center"
                                       Margin ="0,0,10,0"
                                       Foreground ="#ff00ff"/>
                    <TextBlock Text="Timetable"
                         VerticalAlignment="Center"
                         FontSize="16"
                         Foreground="#ff4500"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Calendar HorizontalAlignment="Left" Margin="266,12,0,0" VerticalAlignment="Top"/>
                <Button x:Name="btnSearchSoftware1" Content="Search Software" HorizontalAlignment="Left" Margin="525,319,0,0" VerticalAlignment="Top" Background="Lime" BorderBrush="Lime" Foreground="#FF1E1E1E" FontWeight="Bold" Click="btnSearchSoftware1_Click"/>
                <Button x:Name="btnExamsLabs" Content="Exams Labs" HorizontalAlignment="Left" Margin="686,319,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.255,0.516" Background="Cyan" BorderBrush="Cyan" Foreground="#FF1E1E1E" FontWeight="Bold" Click="btnExamsLabs_Click"/>
            </Grid>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Teacher"
                               Width="25"
                               Height="25"
                               VerticalAlignment="Center"
                               Margin ="0,0,10,0"
                               Foreground ="#ff1493"/>
                    <TextBlock Text="Exams Labs"
                 VerticalAlignment="Center"
                 FontSize="16"
                 Foreground="#1e90ff"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="23*"/>
                    <ColumnDefinition Width="474*"/>
                    <ColumnDefinition Width="303*"/>
                </Grid.ColumnDefinitions>
                <ListBox x:Name="lbxComputerExam" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,38,218,10" Grid.ColumnSpan="2"/>
                <ListBox x:Name="lbxSoftwareAndRoomNumber" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="391,51,36,99" RenderTransformOrigin="0.54,0.525" Grid.ColumnSpan="2" Grid.Column="1"/>
                <Label x:Name="lblSearchExam" Content="Search:" HorizontalAlignment="Left" Margin="245,14,0,0" VerticalAlignment="Top" FontWeight="Bold" Foreground="DarkSlateGray" Grid.Column="1"/>
                <Button x:Name="btnTimetable1" Content="Timetable" HorizontalAlignment="Left" Margin="155,303,0,0" VerticalAlignment="Top" Grid.Column="2" Background="DarkOrange" FontWeight="Bold" BorderBrush="DarkOrange" Foreground="DarkSlateGray" Click="btnTimetable1_Click"/>
                <Button x:Name="btnSearchSoftware" Content="Search Software" HorizontalAlignment="Left" Margin="434,303,0,0" VerticalAlignment="Top" Grid.ColumnSpan="2" Background="SpringGreen" BorderBrush="SpringGreen" Foreground="DarkSlateGray" FontWeight="Bold" Grid.Column="1" Click="btnSearchSoftware_Click"/>
                <ComboBox x:Name="cmbxSearch" Grid.Column="1" HorizontalAlignment="Left" Margin="299,14,0,0" VerticalAlignment="Top" Width="120"/>

            </Grid>
        </TabItem>

    </TabControl>
</Window>
