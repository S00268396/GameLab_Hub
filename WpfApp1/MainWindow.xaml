<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Background>
        <ImageBrush ImageSource="Images/Tab1.jpg" Stretch="UniformToFill"/>
    </Window.Background>   
    <TabControl TabStripPlacement = "Top" Name="tabCTRL">
        
        <!--Search Software Tab-->
        <TabItem x:Name="tblmSearchSoftware" Loaded="tblmSearchSoftware_Loaded">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Computer"
                                          Width="25"
                                          Height="25"
                                          VerticalAlignment="Center"
                                          Margin ="0,0,10,0" 
                                          Foreground="#FF4500"/>
                    <TextBlock Text="Search Software"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#1E90FF"/>
                </StackPanel>
            </TabItem.Header>
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                
                <!--Search part-->
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,10">
                    <Label x:Name="lblComputerlab" Content="Search:" VerticalAlignment="Top" Background="#FFFFFF" FontWeight="Bold" Foreground="Black"/>
                    <TextBox x:Name="tbxSearch" Width="220" Margin="10,0,0,0" VerticalAlignment="Top" materialDesign:HintAssist.Hint="Enter a Computer Lab" Background="Transparent" KeyUp="tbxSearch_KeyUp"/>
                </StackPanel>

                <!--Computer Labs List-->
                <materialDesign:Card Grid.Row="1" Grid.Column="0" Padding="10" Margin="0,0,10,0">
                    <ListBox x:Name="lbxListOfComputer" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10" Background="#FAFAFA" Foreground="Black" SelectionChanged="lbxListOfComputer_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="2" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="SemiBold" Opacity="0.9">
                                            <Run Text="Computer LabID: "/>                                          
                                            <Run Text="{Binding Computer_LabID}"/>
                                            <LineBreak/>
                                            <Run Text="Location: "/>
                                            <Run Text="{Binding Location}"/> 
                                        </TextBlock>
                                    </StackPanel>
                                </Border>                               
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </materialDesign:Card> 
               
               <!--Computer Labs and Computer Info-->
                <materialDesign:Card Grid.Row="1" Grid.Column="1" Padding="15">
                    <StackPanel>
                        <Border Background="#FAFAFA" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                            <TextBlock x:Name="tblRoominfo" TextWrapping="Wrap" Height="220" Text="RoomInfo" Foreground="Black" FontWeight="SemiBold"/>
                        </Border>                       
                    </StackPanel>
                </materialDesign:Card>
                
                <!--Buttons-->
                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,15,0,0">
                    <Button x:Name="btnExamLabs" Content="Exam Labs" FontWeight="Bold" Background="#8000FF" Margin="0,0,10,0" Padding="20,5" Foreground="#FFFFFF" Click="btnExamLabs_Click"/>
                    <Button x:Name="btnTimetable" Content="Timetable" FontWeight="Bold" Background="#8000FF" Foreground="#FFFFFF" Click="btnTimetable_Click"/>
                </StackPanel>
            </Grid>
        </TabItem>

        <!--TimeTable Tab-->
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Timetable"
                                    Width="25"
                                    Height="25"
                                    VerticalAlignment="Center"
                                    Margin ="0,0,10,0"
                                    Foreground ="#FF4500"/>
                    <TextBlock Text="Timetable"
                      VerticalAlignment="Center"
                      FontSize="16"
                      Foreground="#1E90FF"/>
                </StackPanel>
            </TabItem.Header>
            
            <!--Grids-->
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>                
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>                    
                </Grid.ColumnDefinitions>
                
                <!--TimeTable-->
                <DataGrid x:Name="dgTimetable" AutoGenerateColumns="False" IsReadOnly="True" Grid.Row="0" Margin="0,0,0,10" Background="#FFFFFF" Foreground="Black" Loaded="dgTimetable_Loaded" >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Course Name" Binding="{Binding CourseName}" Width="*"/>
                        <DataGridTextColumn Header="Type Of Exam" Binding="{Binding TypeOfExam}" Width="*"/>
                        <DataGridTextColumn Header="Year" Binding="{Binding YearGroup}" Width="*"/>
                        <DataGridTextColumn Header="Teacher" Binding="{Binding TeacherName}" Width="*"/>
                        <DataGridTextColumn Header="Exam Labs" Binding="{Binding Labs}" Width="*"/>
                        <DataGridTextColumn Header="Date Of Exam" Binding="{Binding DateOfexam, StringFormat=dd/MM/yyyy}" Width="*"/>
                        <DataGridTextColumn Header="Time" Binding="{Binding DateOfExam, StringFormat=hh:mm tt}" Width="*"/>
                        <DataGridTextColumn Header="Long Of Time" Binding="{Binding LongOfTime}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                
                <!--Buttons-->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="btnSearchSoftware1" Content="Search Software" Background="#8000FF"  Foreground="#FFFFFF" FontWeight="Bold" Margin="0,0,10,0" Padding="15,5" Click="btnSearchSoftware1_Click"/>
                    <Button x:Name="btnExamsLabs" Content="Exams Labs" Background="#8000FF" Foreground="#FFFFFF" FontWeight="Bold" Padding="15,5" Click="btnExamsLabs_Click"/>
                </StackPanel>
            </Grid>
        </TabItem>

        <!--Exam Labs Tab-->
        <TabItem x:Name="tblmExams_Labs" Loaded="tblmExams_Labs_Loaded">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Teacher"
                            Width="25"
                            Height="25"
                            VerticalAlignment="Center"
                            Margin ="0,0,10,0"
                            Foreground ="#FF4500"/>
                    <TextBlock Text="Exams Labs"
              VerticalAlignment="Center"
              FontSize="16"
              Foreground="#1e90ff"/>
                </StackPanel>
            </TabItem.Header>
            
            <!--Grids-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                
                <!--Filters-->
                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <Label x:Name="lblTypeOfExam" Content="Exam:" FontWeight="Bold" Foreground="Black"/>
                    <ComboBox x:Name="cmbxSearchExam" Width="120" Loaded="cmbxSearchExam_Loaded" Foreground="#FFFFFF" SelectionChanged="cmbxSearchExam_SelectionChanged"/>
                    <Label x:Name="lblYear" Content="Year:" FontWeight="Bold" Foreground="Black"/>
                    <ComboBox x:Name="cmbxSearchYear" Width="120" Loaded="cmbxSearchYear_Loaded" Foreground="Black" SelectionChanged="cmbxSearchYear_SelectionChanged"/>
                    <Label x:Name="lbCourse" Content="Course:" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <ComboBox x:Name="cmbxSearchCourse" Width="120" Loaded="cmbxSearchCourse_Loaded" Foreground="Black" SelectionChanged="cmbxSearchCourse_SelectionChanged"/>
                    <Label x:Name="lblTeacher" Content="Teacher:" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <ComboBox x:Name="cmbxSearchTeacher" Width="120" Loaded="cmbxSearchTeacher_Loaded" Foreground="Black" SelectionChanged="cmbxSearchTeacher_SelectionChanged"/>
                </StackPanel>
                
                <!--List of Exam Labs-->
                <ListBox x:Name="lbxComputerExam" Grid.Row="1" Grid.Column="0" BorderThickness="1" Background="#FAFAFA" Foreground="Black" Padding="5" d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="lbxComputerExam_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="{Binding Exam_LabID}" Margin="0,0,10,0" />
                                <TextBlock Text="{Binding CourseName}" Margin="0,0,10,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <!--Exam and Exam Labs Info-->
                <materialDesign:Card Grid.Row="1" Grid.Column="1" Padding="15" Margin="0,0,0,10" Background="#FAFAFA">
                    <Border Background="#FAFAFA" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                      <TextBlock x:Name="tblExaminfo" TextWrapping="Wrap" FontWeight="SemiBold" Height="240" Foreground="Black" VerticalAlignment="Top" Text="ExamInfo"/>
                    </Border>
                </materialDesign:Card>

                <!--Buttons-->
                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="btnTimetable1" Content="Timetable" Background="#8000FF" Foreground="#FFFFFF" Margin="0,0,10,0" FontWeight="Bold" Padding="15,5" Click="btnTimetable1_Click"/>
                    <Button x:Name="btnSearchSoftware" Content="Search Software" Background="#8000FF" Foreground="#FFFFFF" FontWeight="Bold" Padding="15,5" Click="btnSearchSoftware_Click"/>
                </StackPanel>                
            </Grid>
        </TabItem>
    </TabControl>
</Window>
